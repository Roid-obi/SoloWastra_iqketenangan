---
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "SoloWastra: Exploring the Legacy of Solo Batik",
	description = "Menjembatani mahakarya masa lalu dengan generasi masa kini. Jelajahi sejarah, filosofi, dan keindahan Batik Solo melalui pengalaman digital modern.",
} = Astro.props;
---

<!doctype html>
<html lang="id">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#1c0a00" />

		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300..700;1,9..40,300..700&display=swap"
			rel="stylesheet"
		/>

		<title>{title}</title>
	</head>
	<body class="bg-neutral-light font-body text-neutral-dark antialiased">
		<slot />
	</body>
</html>

<style is:global>
	html {
		scroll-behavior: auto;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		overflow-x: hidden;
	}

	::selection {
		background-color: var(--color-accent);
		color: var(--color-neutral-dark);
	}

	:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 3px;
	}

	@media (prefers-reduced-motion: reduce) {
		*,
		*::before,
		*::after {
			animation-duration: 0.01ms !important;
			animation-iteration-count: 1 !important;
			transition-duration: 0.01ms !important;
			scroll-behavior: auto !important;
		}
	}
</style>
