---
import { Image } from "astro:assets";
import batikSogan1 from "../assets/images/batik_sogan_1.png";
import batikSogan2 from "../assets/images/batik_sogan_2.png";
import batikSogan3 from "../assets/images/batik_sogan_3.png";
import batikSogan4 from "../assets/images/batik_sogan_4.png";
---

<section
	id="hero"
	class="relative w-full h-screen flex flex-col items-center justify-center overflow-hidden bg-[#0d0500]"
>
	<!-- 1. Ambient Background Motion & Gateway Atmosphere -->
	<div class="absolute inset-0 pointer-events-none z-0">
		<div class="hero-ambient-glow absolute inset-0 opacity-40 mix-blend-screen bg-[radial-gradient(circle_at_50%_50%,_#4d1e00_0%,_transparent_65%)]"></div>
		
		<div
			class="absolute inset-0 opacity-15 mix-blend-overlay"
			style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"
		></div>
	</div>

	<!-- 2. SVG Line Art (Bunga Batik Self-Drawing) -->
	<svg class="batik-line-art absolute -top-32 -left-32 w-[32rem] h-[32rem] opacity-0 text-[#cc9544]/20 pointer-events-none z-0" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="0.5">
		<path class="draw-path" d="M50 10 C 60 40, 90 50, 90 50 C 90 50, 60 60, 50 90 C 40 60, 10 50, 10 50 C 10 50, 40 40, 50 10 Z" />
		<circle class="draw-path" cx="50" cy="50" r="10" />
		<circle class="draw-path" cx="50" cy="50" r="4" />
	</svg>
	
	<svg class="batik-line-art absolute -bottom-32 -right-32 w-[32rem] h-[32rem] opacity-0 text-[#cc9544]/20 pointer-events-none z-0 rotate-90" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="0.5">
		<path class="draw-path" d="M50 10 C 60 40, 90 50, 90 50 C 90 50, 60 60, 50 90 C 40 60, 10 50, 10 50 C 10 50, 40 40, 50 10 Z" />
		<circle class="draw-path" cx="50" cy="50" r="10" />
		<circle class="draw-path" cx="50" cy="50" r="4" />
	</svg>

	<!-- 3. Floating Background Cards (3D Depth Illustration) -->
	<!-- Added perspective for true 3D spatial effect -->
	<div
		class="hero-parallax-container absolute inset-0 w-full h-full pointer-events-none z-10"
		style="perspective: 1200px; transform-style: preserve-3d;"
	>
		<!-- Farthest (Paling Jauh) - Kiri Atas -->
		<div
			class="parallax-item absolute top-[8%] left-[4%] w-32 h-48 md:w-40 md:h-56 z-0"
			style="transform: translateZ(-800px) rotate(-15deg);"
			data-direction="-1, -1"
		>
			<div class="float-item w-full h-full shadow-2xl opacity-100 blur-[8px]">
				<!-- Dark overlay to blend into the darkness instead of being transparent -->
				<div class="absolute inset-0 bg-[#0d0500]/60 z-10 pointer-events-none"></div>
				<Image src={batikSogan3} alt="Batik Sogan Jauh" class="w-full h-full object-cover" format="avif" />
			</div>
		</div>

		<!-- Mid-Far (Agak Jauh) - Kanan Atas -->
		<div
			class="parallax-item absolute top-[12%] right-[6%] w-36 h-52 md:w-48 md:h-64 z-10"
			style="transform: translateZ(-600px) rotate(10deg);"
			data-direction="1, -1"
		>
			<div class="float-item w-full h-full shadow-2xl opacity-100 blur-[5px]">
				<div class="absolute inset-0 bg-[#0d0500]/40 z-10 pointer-events-none"></div>
				<Image src={batikSogan4} alt="Batik Sogan Menengah" class="w-full h-full object-cover" format="avif" />
			</div>
		</div>

		<!-- Mid-Close (Agak Dekat) - Kiri Bawah -->
		<div
			class="parallax-item absolute bottom-[15%] left-[10%] w-44 h-60 md:w-56 md:h-72 z-20"
			style="transform: translateZ(-300px) rotate(-8deg);"
			data-direction="-1, 1"
		>
			<div class="float-item w-full h-full shadow-2xl opacity-100 blur-[2px]">
				<div class="absolute inset-0 bg-[#0d0500]/20 z-10 pointer-events-none"></div>
				<Image src={batikSogan1} alt="Batik Sogan Dekat" class="w-full h-full object-cover" format="avif" />
			</div>
		</div>

		<!-- Closest (Paling Dekat) - Kanan Bawah -->
		<div
			class="parallax-item absolute bottom-[8%] right-[8%] w-48 h-64 md:w-64 md:h-80 z-30"
			style="transform: translateZ(0px) rotate(5deg);"
			data-direction="1, 1"
		>
			<div class="float-item w-full h-full shadow-2xl opacity-100 blur-[1px]">
				<div class="absolute inset-0 bg-[#0d0500]/10 z-10 pointer-events-none"></div>
				<Image src={batikSogan2} alt="Batik Sogan Sangat Dekat" class="w-full h-full object-cover" format="avif" />
			</div>
		</div>
	</div>

	<!-- 4. Main Content (Gateway Entry) -->
	<div class="hero-content relative z-40 text-center max-w-4xl px-6 flex flex-col items-center">
		<h1
			class="hero-title text-3xl sm:text-4xl md:text-5xl lg:text-7xl font-heading font-bold text-[#fdfbf7] leading-tight mb-4 sm:mb-6 drop-shadow-xl"
		>
			Menjelajah Mahakarya<br/>
			<span class="text-[#cc9544]">Batik Solo</span>
		</h1>
		<p
			class="hero-subtitle text-base sm:text-lg md:text-xl text-[#c9b69e] mb-10 sm:mb-12 max-w-2xl font-body leading-relaxed drop-shadow-md"
		>
			Sebuah gerbang visual menuju pusaka keraton. Temukan makna, filosofi, dan doa yang terajut dalam setiap helai warna bumi.
		</p>
		
		<!-- Microinteraction Buttons -->
		<div class="hero-buttons flex flex-col sm:flex-row gap-6 mb-16 pointer-events-auto">
			<a
				href="#introduction"
				class="group relative px-8 py-4 bg-[#cc9544] text-[#1c0a00] font-heading font-bold tracking-wide rounded-full overflow-hidden shadow-lg shadow-[#cc9544]/20 transition-transform duration-300 hover:scale-105"
			>
				<span class="relative z-10 flex items-center justify-center">
					Mulai Eksplorasi
				</span>
				<div class="absolute inset-0 bg-[#e0aa58] scale-x-0 origin-left transition-transform duration-500 ease-out group-hover:scale-x-100"></div>
			</a>
			<a
				href="#why-solo"
				class="group relative px-8 py-4 bg-transparent border border-[#cc9544] text-[#cc9544] font-heading font-bold tracking-wide rounded-full overflow-hidden shadow-lg transition-transform duration-300 hover:scale-105 bg-[#0d0500]/50 backdrop-blur-sm"
			>
				<span class="relative z-10 flex items-center justify-center transition-colors duration-300 group-hover:text-[#1c0a00]">
					Kenali SoloWastra
				</span>
				<div class="absolute inset-0 bg-[#cc9544] scale-y-0 origin-bottom transition-transform duration-400 ease-out group-hover:scale-y-100"></div>
			</a>
		</div>
	</div>

	<!-- Scroll Indicator -->
	<div class="hero-scroll-indicator absolute bottom-12 md:bottom-16 left-1/2 -translate-x-1/2 flex flex-col items-center opacity-70 z-40">
		<span class="text-xs font-body uppercase tracking-[0.2em] text-[#cc9544] mb-3">Scroll to Enter</span>
		<div class="w-[1px] h-12 bg-gradient-to-b from-[#cc9544] to-transparent animate-pulse"></div>
	</div>

	<!-- SVG Bottom Divider -->
	<div class="absolute bottom-0 left-0 w-full overflow-hidden leading-[0] z-30 pointer-events-none rotate-180 translate-y-px">
		<svg class="block relative w-full h-[60px] md:h-[100px] lg:h-[140px]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
			<path d="M0,0V46.29c47.79,22.2,103.59,32.17,158,28,70.36-5.37,136.33-33.31,206.8-37.5C438.64,32.43,512.34,53.67,583,72.05c69.27,18,138.3,24.88,209.4,13.08,36.15-6,69.85-17.84,104.45-29.34C989.49,25,1113-14.29,1200,52.47V0Z" opacity=".25" class="fill-[var(--color-neutral-dark)]"></path>
			<path d="M0,0V15.81C13,36.92,27.64,56.86,47.69,72.05,99.41,111.27,165,111,224.58,91.58c31.15-10.15,60.09-26.07,89.67-39.8,40.92-19,84.73-46,130.83-49.67,36.26-2.85,70.9,9.42,98.6,31.56,31.77,25.39,62.32,62,103.63,73,40.44,10.79,81.35-6.69,119.13-24.28s75.16-39,116.92-43.05c59.73-5.85,113.28,22.88,168.9,38.84,30.2,8.66,59,6.17,87.09-7.5,22.43-10.89,48-26.93,60.65-49.24V0Z" opacity=".5" class="fill-[var(--color-neutral-dark)]"></path>
			<path d="M0,0V5.63C149.93,59,314.09,71.32,475.83,42.57c43-7.64,84.23-20.12,127.61-26.46,59-8.63,112.48,12.24,165.56,35.4C827.93,77.22,886,95.24,951.2,90c86.53-7,172.46-45.71,248.8-84.81V0Z" class="fill-[var(--color-neutral-dark)]"></path>
		</svg>
	</div>
</section>

<script>
	import gsap from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	gsap.registerPlugin(ScrollTrigger);

	document.addEventListener("DOMContentLoaded", () => {
		const parallaxItems = document.querySelectorAll(".parallax-item");
		const floatItems = document.querySelectorAll(".float-item");
		
		// 1. Continuous Auto-Floating 3D Animation (Replaces Cursor Parallax)
		floatItems.forEach((item, index) => {
			// Create a gentle random floating animation
			gsap.to(item, {
				y: "+=40", // Float up/down
				rotationX: "+=5", // Tilt slightly 
				rotationY: "+=10",
				duration: gsap.utils.random(4, 7),
				repeat: -1, // Infinite loop
				yoyo: true, // Go back and forth
				ease: "sine.inOut",
				delay: index * 0.5 // Stagger the start time
			});
		});

		// 2. Initial Loading Animations
		const tl = gsap.timeline();
		
		// Ambient Glow Breathe
		gsap.to(".hero-ambient-glow", {
			scale: 1.1,
			opacity: 0.6,
			duration: 4,
			repeat: -1,
			yoyo: true,
			ease: "sine.inOut"
		});

		// SVG Line Art Self-Drawing
		const drawPaths = document.querySelectorAll(".draw-path");
		drawPaths.forEach(path => {
			const length = (path as SVGPathElement).getTotalLength();
			gsap.set(path, { strokeDasharray: length, strokeDashoffset: length });
		});

		tl.to(".batik-line-art", { opacity: 1, duration: 1 })
		  .to(".draw-path", {
			strokeDashoffset: 0,
			duration: 3,
			ease: "power2.inOut",
			stagger: 0.2
		  }, "-=0.5")
		  .from(".hero-title", {
			y: 40,
			opacity: 0,
			duration: 1,
			ease: "power3.out",
		  }, "-=2.5")
		  .from(".hero-subtitle", {
			y: 20,
			opacity: 0,
			duration: 0.8,
			ease: "power3.out",
		  }, "-=2")
		  .from(".hero-buttons a", {
			y: 20,
			opacity: 0,
			duration: 0.6,
			stagger: 0.2,
			ease: "power3.out",
		  }, "-=1.6")
		  .from(parallaxItems, {
			scale: 0.8, // Pop in from smaller scale
			opacity: 0,
			duration: 2,
			stagger: 0.15,
			ease: "power3.out"
		  }, "-=1.5")
		  .from(".hero-scroll-indicator", {
			opacity: 0,
			duration: 1,
		  }, "-=0.5");

		// 3. Gateway Opening Scroll Animation
		const scrollTl = gsap.timeline({
			scrollTrigger: {
				trigger: "#hero",
				start: "top top",
				end: "bottom top",
				scrub: 1,
			}
		});

		// As user scrolls down, scatter the cards outward to reveal the content below
		parallaxItems.forEach(item => {
			const dir = (item.getAttribute("data-direction") || "1, 1").split(",").map(Number);
			// Also move closer (translateZ increase) to feel like passing through them
			scrollTl.to(item, {
				x: dir[0] * window.innerWidth * 0.8,
				y: dir[1] * window.innerHeight * 0.8,
				z: 500, 
				rotationZ: dir[0] * 30,
				opacity: 0,
				ease: "power1.inOut"
			}, 0);
		});

		// Push the main text into the background
		scrollTl.to(".hero-content", {
			y: -150,
			scale: 0.8,
			opacity: 0,
			ease: "power1.inOut"
		}, 0);
		
		// Fade out scroll indicator quickly
		scrollTl.to(".hero-scroll-indicator", {
			opacity: 0,
			duration: 0.1
		}, 0);
	});
</script>
