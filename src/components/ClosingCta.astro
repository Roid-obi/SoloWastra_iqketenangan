---
import BatikOrnament from "./BatikOrnament.astro";
---

<section class="relative overflow-hidden bg-neutral-dark py-28 md:py-36">
	<div class="batik-texture-bg absolute inset-0 opacity-[0.06]"></div>
	<BatikOrnament
		variant="truntum"
		class="pointer-events-none absolute inset-0 h-full w-full text-accent/10"
	/>

	<div class="section-container relative text-center">
		<div class="mx-auto max-w-3xl overflow-hidden">
			<h2
				data-cta-line
				class="text-balance font-heading text-3xl leading-tight text-neutral-light sm:text-4xl md:text-5xl"
			>
				Every Pattern Carries a Story.
			</h2>
		</div>
		<div class="mx-auto max-w-3xl overflow-hidden">
			<h2
				data-cta-line
				class="text-balance font-heading text-3xl leading-tight text-accent sm:text-4xl md:text-5xl"
			>
				Every Story Keeps the Heritage Alive.
			</h2>
		</div>

		<p
			data-cta-fade
			class="mx-auto mt-8 max-w-xl text-balance leading-relaxed text-neutral-light/70 opacity-0"
		>
			Jangan biarkan sejarah berhenti di generasi kita. Mari bersama-sama
			mengapresiasi, menggunakan, dan melestarikan mahakarya kebanggaan
			Indonesia.
		</p>

		<div data-cta-fade class="mt-10 flex flex-wrap items-center justify-center gap-4 opacity-0">
			<a
				href="#explore-motifs"
				class="group inline-flex items-center gap-2 rounded-full bg-accent px-7 py-3.5 text-sm font-semibold text-neutral-dark transition-all duration-300 hover:scale-[1.04] hover:shadow-glow"
			>
				Mulai Lestarikan
			</a>
			<button
				id="share-button"
				type="button"
				class="inline-flex items-center gap-2 rounded-full border border-neutral-light/30 px-7 py-3.5 text-sm font-semibold text-neutral-light transition-colors duration-300 hover:border-accent hover:text-accent"
			>
				Bagikan SoloWastra
			</button>
		</div>
		<p id="share-feedback" class="mt-3 h-4 text-xs text-accent opacity-0 transition-opacity"></p>
	</div>
</section>

<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	gsap.registerPlugin(ScrollTrigger);

	const lines = gsap.utils.toArray<HTMLElement>("[data-cta-line]");
	gsap.fromTo(
		lines,
		{ yPercent: 110 },
		{
			yPercent: 0,
			duration: 0.9,
			ease: "power3.out",
			stagger: 0.12,
			scrollTrigger: { trigger: lines[0]?.closest("section"), start: "top 70%" },
		},
	);

	gsap.to("[data-cta-fade]", {
		opacity: 1,
		duration: 0.8,
		ease: "power2.out",
		stagger: 0.1,
		delay: 0.4,
		scrollTrigger: { trigger: lines[0]?.closest("section"), start: "top 70%" },
	});

	const shareButton = document.getElementById("share-button");
	const feedback = document.getElementById("share-feedback");

	shareButton?.addEventListener("click", async () => {
		const shareData = {
			title: "SoloWastra: Exploring the Legacy of Solo Batik",
			text: "Jelajahi sejarah, filosofi, dan keindahan 12 motif Batik Solo.",
			url: window.location.href,
		};

		try {
			if (navigator.share) {
				await navigator.share(shareData);
			} else {
				await navigator.clipboard.writeText(shareData.url);
				if (feedback) {
					feedback.textContent = "Tautan disalin ke clipboard!";
					feedback.style.opacity = "1";
					setTimeout(() => {
						feedback.style.opacity = "0";
					}, 2500);
				}
			}
		} catch {
			// User cancelled share sheet - no action needed.
		}
	});
</script>
