---
// BatikModal.astro
---

<div id="batik-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 md:p-8 opacity-0 pointer-events-none">
	<!-- Backdrop -->
	<div id="modal-backdrop" class="absolute inset-0 bg-[#1c0a00] bg-opacity-80 backdrop-blur-md cursor-pointer"></div>
	
	<!-- Modal Content (Kertas Surat Style) -->
	<div id="modal-content" class="relative w-full max-w-6xl max-h-[90vh] bg-[#eedfcc] text-[#2c1808] p-8 md:p-12 shadow-2xl border border-[#d4c3a3] overflow-y-auto flex flex-col md:flex-row gap-8 scale-95 transform">
		<!-- Texture overlay -->
		<div class="absolute inset-0 opacity-60 pointer-events-none mix-blend-multiply" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.8%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>
		
		<!-- Close Button -->
		<button id="close-modal" class="absolute top-4 right-4 md:top-6 md:right-6 z-20 text-[#603601] hover:text-[#cc9544] transition-colors p-2">
			<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
			</svg>
		</button>

		<!-- Image Section -->
		<div class="relative z-10 w-full md:w-1/3 flex-shrink-0 flex items-start justify-center">
			<div class="border-4 border-[#eedfcc] shadow-xl w-full max-w-sm">
				<img id="modal-image" src="" alt="Batik Motif" class="w-full h-auto object-cover border border-[#8a5a2b] border-opacity-30" />
			</div>
		</div>

		<!-- Details Section -->
		<div class="relative z-10 w-full md:w-2/3 flex flex-col gap-6 mix-blend-multiply">
			<h2 id="modal-title" class="text-4xl md:text-5xl font-heading font-bold text-[#603601] border-b-2 border-[#d4c3a3] pb-4">
				Batik Motif
			</h2>
			
			<div>
				<h4 class="text-xl font-heading font-bold text-[#8a5a2b] mb-1">Makna Singkat</h4>
				<p id="modal-makna" class="text-lg font-body italic text-[#361500]"></p>
			</div>
			
			<div>
				<h4 class="text-xl font-heading font-bold text-[#8a5a2b] mb-1">Tentang Motif</h4>
				<p id="modal-tentang" class="text-lg font-body leading-relaxed text-[#361500]"></p>
			</div>
			
			<div>
				<h4 class="text-xl font-heading font-bold text-[#8a5a2b] mb-1">Filosofi</h4>
				<ul id="modal-filosofi" class="list-disc list-outside ml-6 text-lg font-body leading-relaxed text-[#361500] space-y-1">
				</ul>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-4 border-t border-[#d4c3a3] border-opacity-50">
				<div>
					<h4 class="text-xl font-heading font-bold text-[#8a5a2b] mb-1">Digunakan Untuk</h4>
					<p id="modal-kegunaan" class="text-lg font-body leading-relaxed text-[#361500] font-semibold"></p>
				</div>
				<div>
					<h4 class="text-xl font-heading font-bold text-[#8a5a2b] mb-1">Fakta Menarik</h4>
					<p id="modal-fakta" class="text-lg font-body leading-relaxed text-[#361500]"></p>
				</div>
			</div>
		</div>
	</div>
</div>

<script>
	import gsap from "gsap";
	import batikData from "../data/batik.json";
	
	// Helper to resolve images for the client
	// Since Astro compiles assets, we'll manually map the filenames to the processed URL if needed,
	// but an easier way for client-side rendering is to use the public folder or rely on Vite's asset imports.
	// Since we need it dynamically on the client, we can define a map of images.
	const imageModules = import.meta.glob<{ default: { src: string } }>("../assets/images/*.png", { eager: true });
	const getImageUrl = (filename: string) => {
		const key = `../assets/images/${filename}`;
		return imageModules[key]?.default.src || "";
	};

	document.addEventListener("DOMContentLoaded", () => {
		const modal = document.getElementById("batik-modal");
		const backdrop = document.getElementById("modal-backdrop");
		const content = document.getElementById("modal-content");
		const closeBtn = document.getElementById("close-modal");

		// DOM Elements to populate
		const elTitle = document.getElementById("modal-title");
		const elImage = document.getElementById("modal-image") as HTMLImageElement;
		const elMakna = document.getElementById("modal-makna");
		const elTentang = document.getElementById("modal-tentang");
		const elFilosofi = document.getElementById("modal-filosofi");
		const elKegunaan = document.getElementById("modal-kegunaan");
		const elFakta = document.getElementById("modal-fakta");

		// Function to open modal
		const openModal = (id: string) => {
			const data = batikData.find(item => item.id === id);
			if (!data) return;

			// Populate Data
			if (elTitle) elTitle.innerText = data.name;
			if (elMakna) elMakna.innerText = data.makna;
			if (elTentang) elTentang.innerText = data.tentang;
			if (elKegunaan) elKegunaan.innerText = data.kegunaan;
			if (elFakta) elFakta.innerText = data.fakta;
			
			if (elImage) {
				elImage.src = getImageUrl(data.image);
				elImage.alt = data.name;
			}
			
			if (elFilosofi) {
				elFilosofi.innerHTML = "";
				data.filosofi.forEach(poin => {
					const li = document.createElement("li");
					li.innerText = poin;
					elFilosofi.appendChild(li);
				});
			}

			// Play GSAP Animation
			if (modal && content) {
				modal.style.pointerEvents = "auto";
				// Disable lenis scroll
				document.documentElement.classList.add("overflow-hidden");
				
				gsap.to(modal, { opacity: 1, duration: 0.4, ease: "power2.out" });
				gsap.fromTo(content, 
					{ scale: 0.95, y: 20 },
					{ scale: 1, y: 0, duration: 0.5, ease: "back.out(1.5)" }
				);
			}
		};

		// Function to close modal
		const closeModal = () => {
			if (modal && content) {
				gsap.to(modal, { opacity: 0, duration: 0.3, ease: "power2.inOut", onComplete: () => {
					modal.style.pointerEvents = "none";
					document.documentElement.classList.remove("overflow-hidden");
				}});
				gsap.to(content, { scale: 0.95, y: 20, duration: 0.3, ease: "power2.inOut" });
			}
		};

		// Listen to custom event
		window.addEventListener("openBatikModal", ((e: CustomEvent) => {
			openModal(e.detail.id);
		}) as EventListener);

		// Listen to gallery card clicks
		document.addEventListener("click", (e) => {
			const card = (e.target as HTMLElement).closest(".batik-gallery-card");
			if (card) {
				const id = card.getAttribute("data-batik-id");
				if (id) openModal(id);
			}
		});

		// Close events
		if (closeBtn) closeBtn.addEventListener("click", closeModal);
		if (backdrop) backdrop.addEventListener("click", closeModal);
		
		// ESC key
		document.addEventListener("keydown", (e) => {
			if (e.key === "Escape" && modal?.style.pointerEvents === "auto") {
				closeModal();
			}
		});
	});
</script>
