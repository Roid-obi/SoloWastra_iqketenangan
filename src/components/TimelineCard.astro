---
interface Props {
    image: string;
    title: string;
    description: string;
    right: boolean;
}

const { image, title, description } = Astro.props as Props;
---

<div class=`bg-neutral-light flex flex-col justify-center items-center gap-4 p-4 rounded-xl w-125`>
    <div>
        <img src={image} alt={title} class="object-cover rounded-xl aspect-square"/>
    </div>
    <div class="flex flex-col gap-2">
        <h3 class="text-lg sm:text-3xl font-bold text-black font-heading">{title}</h3>
        <p class="text-xs sm:text-lg text-black font-body">{description}</p>
    </div>
</div>

