---
interface Props {
  image: string;
  title: string;
  description: string;
  right: boolean;
}

const { image, title, description } = Astro.props as Props;
---

<!--
  Mobile / md  (< 1024px): card 320px max, gambar landscape 3:2
  lg+ (≥ 1024px)         : card 500px, gambar square 1:1
-->
<div
  class="relative bg-[#eedfcc] p-3 lg:p-4 border border-[#c8a97a] shadow-xl w-[min(80vw,320px)] lg:w-125"
>
  <div
    class="absolute inset-0 opacity-50 pointer-events-none mix-blend-multiply"
    style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.8%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E');"
  ></div>

  <div class="relative overflow-hidden border border-[#a07840]/30 w-full mb-3 lg:mb-4">
    <img
      src={image}
      alt={title}
      class="w-full object-cover aspect-3/2 lg:aspect-square"
      height="512"
      width="512"
    />
  </div>

  <div class="relative flex flex-col gap-1 lg:gap-2 pt-1 pb-1 px-1 mix-blend-multiply text-center">
    <h3
      class="text-sm md:text-base lg:text-3xl font-bold text-[#3d1a06] font-heading leading-tight"
    >
      {title}
    </h3>
    <p
      class="text-[11px] md:text-xs lg:text-base text-[#3d1a06]/80 font-body leading-snug"
    >
      {description}
    </p>
  </div>
</div>
