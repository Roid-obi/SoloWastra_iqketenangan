---
interface Props {
    image: string;
    title: string;
    description: string;
}

const { image, title, description } = Astro.props as Props;
---

<div class="w-50 sm:w-100 font-body bg-neutral-light p-4 flex flex-col gap-4 justify-center items-center rounded-2xl">
    <img src={image} alt={title} class="aspect-video object-cover rounded-xl"/>
    <div class ="flex flex-col gap-2 text-center">
        <h1 class="text-lg sm:text-xl font-bold">{title}</h1>
        <p class="text-xs sm:text-sm">{description}</p>
    </div>
</div>