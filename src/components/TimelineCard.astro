---
interface Props {
  image: string;
  title: string;
  description: string;
  right: boolean;
}

const { image, title, description } = Astro.props as Props;
---

<!--
  Mobile / md  (< 1024px): card 320px max, gambar landscape 3:2
  lg+ (≥ 1024px)         : card 500px, gambar square 1:1
-->
<div
  class="bg-neutral-light flex flex-col gap-2.5 lg:gap-4 p-3 lg:p-4 rounded-xl w-[min(80vw,320px)] lg:w-125"
>
  <div class="w-full">
    <img
      src={image}
      alt={title}
      class="object-cover rounded-lg lg:rounded-xl w-full aspect-3/2 lg:aspect-square"
      height="512"
      width="512"
    />
  </div>
  <div class="flex flex-col gap-1 lg:gap-2">
    <h3
      class="text-sm md:text-base lg:text-3xl font-bold text-black font-heading leading-tight"
    >
      {title}
    </h3>
    <p
      class="text-[11px] md:text-xs lg:text-lg text-black/70 font-body leading-snug"
    >
      {description}
    </p>
  </div>
</div>
