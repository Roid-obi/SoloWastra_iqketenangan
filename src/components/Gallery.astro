---
import batikData from "../data/batik.json";
import { Image } from "astro:assets";

const images = import.meta.glob<{ default: ImageMetadata }>(
	"../assets/images/*.png",
	{ eager: true },
);

// Card rotations — alternating subtle angles for organic feel
const rotations = ["-2deg", "1.5deg", "-1deg", "2.5deg", "-2.5deg", "1deg", "-1.5deg", "2deg"];
---

<section id="gallery-section" class="relative w-full py-32 px-6 overflow-visible">
	
	<!-- Section Header -->
	<div class="gallery-header text-center max-w-3xl mx-auto mb-16 md:mb-20 opacity-0 translate-y-8">
		<p class="font-body text-[#cc9544] tracking-[0.25em] uppercase text-xs sm:text-sm mb-4">
			Eksplorasi Koleksi
		</p>
		<h2 class="font-heading text-4xl sm:text-5xl md:text-6xl font-bold text-[#fdfbf7] mb-6 leading-tight">
			Eksplorasi Mahakarya<br />
			<span class="text-[#cc9544]">Wastra</span>
		</h2>
		<div class="w-16 sm:w-20 h-px bg-[#cc9544] mx-auto mb-6"></div>
		<p class="font-body text-[#c9b69e] text-base sm:text-lg leading-relaxed px-4">
			Delapan mahakarya, delapan cerita. Temukan makna luhur, filosofi, dan doa
			yang tersembunyi di balik indahnya guratan malam Batik Solo.
			Klik pada setiap motif untuk menelusuri kisahnya.
		</p>
	</div>

	<!-- Cards Grid -->
	<div class="gallery-grid max-w-6xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 md:gap-10 items-start">
		{
			batikData.map((item, index) => {
				const imageSrc = images[`../assets/images/${item.image}`]?.default;
				const rotation = rotations[index] ?? "0deg";
				if (!imageSrc) return null;
				return (
					<div
						class="batik-gallery-card group relative cursor-pointer opacity-0 translate-y-12"
						data-batik-id={item.id}
						style={`--card-rotation: ${rotation};`}
					>
						{/* Card wrapper with paper effect */}
						<div
							class="relative bg-[#eedfcc] p-3 border border-[#c8a97a] shadow-xl transition-all duration-500 ease-out"
							style={`transform: rotate(${rotation}); transform-origin: center center;`}
						>
							{/* Texture overlay */}
							<div
								class="absolute inset-0 opacity-50 pointer-events-none mix-blend-multiply"
								style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.8%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E');"
							/>

							{/* Image */}
							<div class="relative overflow-hidden border border-[#a07840]/30 aspect-[3/4]">
								<Image
									src={imageSrc}
									alt={item.name}
									class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
									format="avif"
								/>
								{/* Hover overlay */}
								<div class="absolute inset-0 bg-[#1c0a00]/0 group-hover:bg-[#1c0a00]/40 transition-colors duration-400 flex items-end p-3">
									<span class="text-[#fdfbf7] text-xs font-body tracking-wide opacity-0 group-hover:opacity-100 transition-opacity duration-300 translate-y-2 group-hover:translate-y-0">
										Lihat Detail →
									</span>
								</div>
							</div>

							{/* Card Label */}
							<div class="pt-3 pb-1 px-1 mix-blend-multiply">
								<p class="font-heading text-[#3d1a06] text-sm font-bold leading-tight text-center">
									{item.name}
								</p>
							</div>
						</div>

						{/* Hover lift shadow */}
						<div class="absolute -inset-1 bg-[#cc9544]/0 group-hover:bg-[#cc9544]/8 rounded-none transition-all duration-500 -z-10 blur-xl" />
					</div>
				);
			})
		}
	</div>
</section>

<style>
	.batik-gallery-card .group:hover > div:first-child {
		transform: rotate(0deg) translateY(-6px) !important;
		box-shadow: 0 20px 40px rgba(28, 10, 0, 0.4);
	}
</style>

<script>
	import gsap from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	gsap.registerPlugin(ScrollTrigger);

	document.addEventListener("DOMContentLoaded", () => {
		// 1. Animate the section header
		gsap.to(".gallery-header", {
			opacity: 1,
			y: 0,
			duration: 1,
			ease: "power3.out",
			scrollTrigger: {
				trigger: "#gallery-section",
				start: "top 75%",
			},
		});

		// 2. Animate each card with staggered fade + blur reveal
		const cards = document.querySelectorAll(".batik-gallery-card");

		gsap.set(cards, { filter: "blur(12px)" });

		gsap.to(cards, {
			opacity: 1,
			y: 0,
			filter: "blur(0px)",
			duration: 0.9,
			ease: "power3.out",
			stagger: {
				amount: 1.2,
				from: "start",
			},
			scrollTrigger: {
				trigger: ".gallery-grid",
				start: "top 80%",
			},
		});

		// 3. Subtle hover parallax on individual cards
		cards.forEach((card) => {
			const inner = card.querySelector(".bg-\\[\\#eedfcc\\]") as HTMLElement;
			if (!inner) return;

			card.addEventListener("mousemove", (e: Event) => {
				const mouseEvent = e as MouseEvent;
				const rect = card.getBoundingClientRect();
				const cx = rect.left + rect.width / 2;
				const cy = rect.top + rect.height / 2;
				const dx = (mouseEvent.clientX - cx) / (rect.width / 2);
				const dy = (mouseEvent.clientY - cy) / (rect.height / 2);

				gsap.to(inner, {
					rotationY: dx * 6,
					rotationX: -dy * 6,
					transformPerspective: 600,
					ease: "power2.out",
					duration: 0.3,
					translateY: -8,
					boxShadow: "0 24px 48px rgba(28,10,0,0.45)",
				});
			});

			card.addEventListener("mouseleave", () => {
				const rotation = card.style.getPropertyValue("--card-rotation") || "0deg";
				gsap.to(inner, {
					rotationY: 0,
					rotationX: 0,
					translateY: 0,
					boxShadow: "0 4px 16px rgba(28,10,0,0.2)",
					ease: "power3.out",
					duration: 0.6,
				});
			});
		});
	});
</script>
