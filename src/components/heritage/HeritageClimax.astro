---
/**
 * HeritageClimax.astro
 * ------------------------------------------------------------------
 * The emotional climax of the SoloWastra story — the moment the site
 * moves from "look at this craft" to "this is why it matters."
 *
 * Signature element: the "benang canting" (canting thread) — a single
 * hand-drawn line that runs down the center of the section like wax
 * flowing from a canting pen. A faint, complete line already sits in
 * the background (the heritage that exists, quietly, whether or not
 * anyone tends to it). As the reader scrolls, a second line — in the
 * accent gold — traces over it. That's the point of the section:
 * heritage isn't preserved by accident, it's traced forward on
 * purpose, by someone choosing to pick up the pen.
 *
 * Built with Astro + scoped CSS + a small GSAP/ScrollTrigger script.
 * No client framework needed — everything here is static markup with
 * progressive, scroll-driven enhancement.
 */

const eyebrow = "SDG 11 • Sustainable Cities & Communities";

const milestones = [
	{
		index: "01",
		plate: "Plat 01 — Motif Kawung",
		title: "Menjaga Identitas Lokal",
		body: "Setiap motif menyimpan bahasa yang tak lagi terucap — garis yang menandai asal, status, dan doa. Merawatnya berarti menjaga Solo tetap bisa mengenali wajahnya sendiri.",
		side: "left",
		visual: "motif",
	},
	{
		index: "02",
		plate: "Plat 02 — Tangan Pengrajin, Laweyan",
		title: "Memberdayakan Pengrajin Lokal",
		body: "Di balik satu lembar kain, ada tangan yang bekerja diam-diam selama berminggu-minggu. Mendukung pengrajin adalah cara memastikan keahlian ini tak berhenti pada satu generasi.",
		side: "right",
		visual: "artisan",
	},
	{
		index: "03",
		plate: "Arsip Baru — Digital",
		title: "Menginspirasi Generasi Muda",
		body: "Batik bertahan bukan karena diawetkan, tapi karena terus ditemukan ulang. Generasi baru menerjemahkannya ke bahasa visual dan ruang digital yang mereka pahami.",
		side: "left",
		visual: "digital",
	},
];
---

<section class="hc" id="warisan" aria-labelledby="hc-heading">
	<!-- Ambient background: texture, glow, hairlines, dust — all decorative -->
	<div class="hc-atmosphere" aria-hidden="true">
		<div class="hc-texture"></div>
		<div class="hc-glow"></div>
		<div class="hc-hairlines"></div>
		<div class="hc-dust">
			{Array.from({ length: 14 }).map((_, i) => <span class={`hc-mote hc-mote--${i % 7}`}></span>)}
		</div>
	</div>

	<header class="hc-intro">
		<p class="hc-eyebrow">
			<span class="hc-eyebrow-rule" aria-hidden="true"></span>
			{eyebrow}
		</p>

		<h2 class="hc-heading" id="hc-heading">
			<span class="hc-mask"><span class="hc-line">Merawat Budaya,</span></span>
			<span class="hc-mask"><span class="hc-line">Membangun Masa Depan.</span></span>
		</h2>

		<p class="hc-paragraph">
			Batik Solo bukan sekadar kain bermotif. Ia adalah ingatan yang dijahit tangan, cara
			sebuah kota menyimpan siapa dirinya — dan menyerahkannya, selembar demi selembar, kepada
			generasi yang akan datang.
		</p>
	</header>

	<div class="hc-timeline">
		<svg
			class="hc-thread"
			viewBox="0 0 100 1200"
			preserveAspectRatio="none"
			aria-hidden="true"
			focusable="false"
		>
			<defs>
				<mask id="hc-thread-mask">
					<rect class="hc-thread-mask-rect" x="0" y="0" width="100" height="0" fill="white" />
				</mask>
			</defs>
			<path
				class="hc-thread-track"
				d="M50,0 C58,60 42,120 50,180 S60,300 50,360 40,480 50,540 60,660 50,720 40,840 50,900 60,1020 50,1080 44,1160 50,1200"
				fill="none"
			></path>
			<path
				class="hc-thread-draw"
				mask="url(#hc-thread-mask)"
				d="M50,0 C58,60 42,120 50,180 S60,300 50,360 40,480 50,540 60,660 50,720 40,840 50,900 60,1020 50,1080 44,1160 50,1200"
				fill="none"
			></path>
			<circle class="hc-tip-glow" cx="50" cy="0" r="9"></circle>
			<circle class="hc-tip-core" cx="50" cy="0" r="2.6"></circle>
		</svg>

		<ol class="hc-milestones">
			{
				milestones.map((m) => (
					<li class={`hc-milestone hc-milestone--${m.side}`}>
						<span class="hc-node" aria-hidden="true"></span>

						<div class="hc-exhibit">
						<div class="hc-frame">
							{m.visual === "motif" && (
								<svg class="hc-visual" viewBox="0 0 160 160" aria-hidden="true">
									<circle cx="80" cy="80" r="70" class="hc-v-ring" fill="none" />
									<circle cx="80" cy="80" r="58" class="hc-v-ring hc-v-ring--dim" fill="none" />
									<g class="hc-v-kawung">
										<ellipse cx="80" cy="52" rx="16" ry="26" />
										<ellipse cx="108" cy="80" rx="26" ry="16" />
										<ellipse cx="80" cy="108" rx="16" ry="26" />
										<ellipse cx="52" cy="80" rx="26" ry="16" />
									</g>
									<circle cx="80" cy="52" r="2.4" class="hc-v-dot" />
									<circle cx="108" cy="80" r="2.4" class="hc-v-dot" />
									<circle cx="80" cy="108" r="2.4" class="hc-v-dot" />
									<circle cx="52" cy="80" r="2.4" class="hc-v-dot" />
									<circle cx="80" cy="80" r="3.2" class="hc-v-dot" />
								</svg>
							)}

							{m.visual === "artisan" && (
								<svg class="hc-visual" viewBox="0 0 220 160" aria-hidden="true">
									<rect x="0" y="0" width="220" height="160" class="hc-v-wash" rx="2" />
									<path
										class="hc-v-cloth"
										d="M20,128 C55,118 85,134 120,124 S180,110 200,120"
										fill="none"
									/>
									<path
										class="hc-v-cloth hc-v-cloth--dim"
										d="M20,140 C55,130 85,146 120,136 S180,122 200,132"
										fill="none"
									/>
									<path
										class="hc-v-hand"
										d="M118,96 C124,84 136,78 148,80 C158,82 163,90 160,98 C168,94 176,98 175,106 C182,105 186,112 181,118 C186,120 186,128 178,130 C168,136 150,138 138,132 C126,127 116,118 112,108 Z"
									/>
									<path
										class="hc-v-canting"
										d="M112,108 L84,120 M84,120 L74,116 M84,120 C80,124 74,124 70,120"
										fill="none"
									/>
									<path class="hc-v-wax" d="M70,120 C64,122 60,127 60,132" fill="none" />
									<circle class="hc-v-dot" cx="59" cy="134" r="1.6" />
								</svg>
							)}

							{m.visual === "digital" && (
								<svg class="hc-visual" viewBox="0 0 220 160" aria-hidden="true">
									<path
										class="hc-v-vine"
										d="M14,120 C34,80 30,50 54,40 C70,33 76,50 66,60 C82,54 92,68 82,80"
										fill="none"
									/>
									<g class="hc-v-grid">
										{Array.from({ length: 6 }).map((_, row) =>
											Array.from({ length: 8 }).map((_, col) => {
												const opacity = Math.max(0.12, 1 - (row + col) * 0.11);
												return (
													<rect
														x={100 + col * 15}
														y={20 + row * 15}
														width="9"
														height="9"
														style={`opacity:${opacity.toFixed(2)}`}
													/>
												);
											}),
										)}
									</g>
									<path
										class="hc-v-vine hc-v-vine--link"
										d="M82,80 C92,88 96,96 100,102"
										fill="none"
									/>
								</svg>
							)}
						</div>
						<p class="hc-plate">{m.plate}</p>
						</div>

						<div class="hc-copy">
							<span class="hc-num" aria-hidden="true">{m.index}</span>
							<h3><span class="hc-num-inline">{m.index}</span>{m.title}</h3>
							<p>{m.body}</p>
						</div>
					</li>
				))
			}
		</ol>
	</div>

	<figure class="hc-quote">
		<blockquote>
			<p class="hc-quote-line">
				<span class="hc-mask"><span class="hc-line">“Warisan bukan hanya tentang apa yang kita terima.</span></span>
			</p>
			<p class="hc-quote-line">
				<span class="hc-mask"><span class="hc-line">Tetapi tentang apa yang kita pilih untuk teruskan.”</span></span>
			</p>
		</blockquote>
		<figcaption>— SoloWastra</figcaption>
	</figure>

	<div class="hc-thread-continue" aria-hidden="true"></div>
</section>

<style>
	.hc {
		--hc-bg: var(--color-neutral-dark, #1c0a00);
		--hc-surface: var(--color-secondary, #361500);
		--hc-motif: var(--color-primary, #603601);
		--hc-gold: var(--color-accent, #cc9544);
		--hc-ivory: var(--color-ivory, #f7f2ea);
		--hc-heading-font: var(--font-heading, "Fraunces", serif);
		--hc-body-font: var(--font-body, "Inter", sans-serif);
		--hc-edge: clamp(1.5rem, 5vw, 6vw);

		position: relative;
		background: var(--hc-bg);
		color: var(--hc-ivory);
		font-family: var(--hc-body-font);
		padding-inline: var(--hc-edge);
		overflow-x: clip;
		isolation: isolate;
	}

	/* ---------------------------------- atmosphere ---------------------------------- */

	.hc-atmosphere {
		position: absolute;
		inset: 0;
		z-index: 0;
		pointer-events: none;
	}

	.hc-texture {
		position: absolute;
		inset: 0;
		background-image: url("/batik-texture.png");
		background-size: 640px;
		background-repeat: repeat;
		opacity: 0.05;
		mix-blend-mode: overlay;
	}

	.hc-glow {
		position: absolute;
		top: -10%;
		left: 50%;
		width: min(1100px, 140vw);
		height: 60vh;
		transform: translateX(-50%);
		background: radial-gradient(closest-side, rgba(204, 149, 68, 0.16), transparent 72%);
		filter: blur(2px);
	}

	.hc-hairlines {
		position: absolute;
		inset: 0;
		opacity: 0.5;
		background-image: repeating-linear-gradient(
			115deg,
			rgba(96, 54, 1, 0.55) 0px,
			rgba(96, 54, 1, 0.55) 1px,
			transparent 1px,
			transparent 160px
		);
	}

	.hc-dust {
		position: absolute;
		inset: 0;
		overflow: hidden;
	}

	.hc-mote {
		position: absolute;
		width: 3px;
		height: 3px;
		border-radius: 50%;
		background: var(--hc-gold);
		opacity: 0.35;
		animation: hc-float 14s ease-in-out infinite;
	}

	.hc-mote--0 { top: 12%; left: 8%; animation-delay: 0s; animation-duration: 16s; }
	.hc-mote--1 { top: 30%; left: 88%; animation-delay: -3s; animation-duration: 19s; }
	.hc-mote--2 { top: 52%; left: 18%; animation-delay: -6s; animation-duration: 15s; }
	.hc-mote--3 { top: 68%; left: 72%; animation-delay: -1.5s; animation-duration: 21s; }
	.hc-mote--4 { top: 22%; left: 50%; animation-delay: -8s; animation-duration: 17s; }
	.hc-mote--5 { top: 82%; left: 34%; animation-delay: -4s; animation-duration: 20s; }
	.hc-mote--6 { top: 40%; left: 62%; animation-delay: -10s; animation-duration: 18s; }
	.hc-mote:nth-child(n + 8) { transform: scale(0.6); opacity: 0.22; }

	@keyframes hc-float {
		0%, 100% { transform: translate3d(0, 0, 0); opacity: 0.25; }
		50% { transform: translate3d(6px, -22px, 0); opacity: 0.55; }
	}

	/* ------------------------------------ intro ------------------------------------- */

	.hc-intro {
		position: relative;
		z-index: 1;
		max-width: 1180px;
		margin-inline: auto;
		padding-top: clamp(5.5rem, 14vh, 9rem);
		padding-bottom: clamp(3rem, 8vh, 5rem);
	}

	.hc-eyebrow {
		display: flex;
		align-items: center;
		gap: 0.85rem;
		margin: 0 0 clamp(1.5rem, 4vh, 2.5rem);
		font-size: clamp(0.68rem, 0.62rem + 0.2vw, 0.8rem);
		font-weight: 500;
		letter-spacing: 0.28em;
		text-transform: uppercase;
		color: var(--hc-gold);
	}

	.hc-eyebrow-rule {
		display: inline-block;
		width: 32px;
		height: 1px;
		background: var(--hc-gold);
		opacity: 0.8;
	}

	.hc-heading {
		font-family: var(--hc-heading-font);
		font-optical-sizing: auto;
		font-weight: 400;
		font-size: clamp(2.75rem, 1.9rem + 4.4vw, 6.4rem);
		line-height: 1.04;
		letter-spacing: -0.01em;
		margin: 0;
		color: var(--hc-ivory);
	}

	.hc-mask {
		display: block;
		overflow: hidden;
	}

	.hc-line {
		display: block;
		transform: translateY(112%);
		will-change: transform;
	}

	.hc-paragraph {
		margin: clamp(1.75rem, 4vh, 2.75rem) 0 0;
		max-width: 42ch;
		font-size: clamp(1rem, 0.94rem + 0.3vw, 1.15rem);
		line-height: 1.75;
		color: color-mix(in srgb, var(--hc-ivory) 78%, transparent);
		opacity: 0;
	}

	/* ---------------------------------- timeline ------------------------------------ */

	.hc-timeline {
		position: relative;
		z-index: 1;
		max-width: 1180px;
		margin-inline: auto;
		padding-block: clamp(2rem, 6vh, 4rem);
	}

	.hc-thread {
		position: absolute;
		top: 0;
		left: 50%;
		width: 64px;
		height: 100%;
		transform: translateX(-50%);
		overflow: visible;
	}

	.hc-thread-track,
	.hc-thread-draw {
		stroke-width: 1.4;
		vector-effect: non-scaling-stroke;
	}

	.hc-thread-track {
		stroke: var(--hc-motif);
		opacity: 0.55;
	}

	.hc-thread-draw {
		stroke: var(--hc-gold);
	}

	.hc-tip-glow {
		fill: var(--hc-gold);
		opacity: 0.35;
		filter: blur(3px);
	}

	.hc-tip-core {
		fill: var(--hc-gold);
	}

	.hc-milestones {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
	}

	.hc-milestone {
		display: grid;
		grid-template-columns: 1fr 64px 1fr;
		align-items: center;
		column-gap: clamp(1.5rem, 4vw, 3.5rem);
		padding-block: clamp(3.5rem, 11vh, 8rem);
		opacity: 0;
	}

	.hc-milestone--left .hc-exhibit,
	.hc-milestone--left .hc-copy {
		grid-column: 1;
	}

	.hc-milestone--right .hc-exhibit,
	.hc-milestone--right .hc-copy {
		grid-column: 3;
	}

	.hc-milestone--right {
		text-align: right;
	}

	.hc-milestone--right .hc-copy {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
	}

	.hc-milestone--right .hc-num {
		right: -0.5rem;
		left: auto;
	}

	.hc-node {
		grid-column: 2;
		justify-self: center;
		width: 11px;
		height: 11px;
		border-radius: 50%;
		background: var(--hc-motif);
		box-shadow: 0 0 0 0 transparent;
		position: relative;
		transition: background 0.4s ease, box-shadow 0.4s ease;
	}

	.hc-node.is-active {
		background: var(--hc-gold);
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--hc-gold) 22%, transparent);
	}

	.hc-node::after {
		content: "";
		position: absolute;
		inset: -10px;
		border-radius: 50%;
		border: 1px solid color-mix(in srgb, var(--hc-gold) 35%, transparent);
		opacity: 0;
		transition: opacity 0.4s ease;
	}

	.hc-node.is-active::after {
		opacity: 1;
		animation: hc-pulse 3.4s ease-out infinite;
	}

	@keyframes hc-pulse {
		0% { transform: scale(0.6); opacity: 0.6; }
		100% { transform: scale(1.6); opacity: 0; }
	}

	/* ---------------------------------- exhibits ------------------------------------ */

	.hc-exhibit {
		max-width: 320px;
	}

	.hc-milestone--right .hc-exhibit {
		margin-left: auto;
	}

	.hc-frame {
		position: relative;
		padding: clamp(1.5rem, 2.5vw, 2.25rem);
		background: linear-gradient(
			160deg,
			color-mix(in srgb, var(--hc-surface) 85%, var(--hc-gold) 5%),
			var(--hc-bg) 130%
		);
		border: 1px solid color-mix(in srgb, var(--hc-gold) 20%, transparent);
	}

	.hc-frame::before {
		content: "";
		position: absolute;
		inset: -7px;
		opacity: 0.7;
		background:
			linear-gradient(to right, var(--hc-gold) 1px, transparent 1px) top left / 14px 1px no-repeat,
			linear-gradient(to bottom, var(--hc-gold) 1px, transparent 1px) top left / 1px 14px no-repeat,
			linear-gradient(to left, var(--hc-gold) 1px, transparent 1px) top right / 14px 1px no-repeat,
			linear-gradient(to bottom, var(--hc-gold) 1px, transparent 1px) top right / 1px 14px no-repeat,
			linear-gradient(to right, var(--hc-gold) 1px, transparent 1px) bottom left / 14px 1px no-repeat,
			linear-gradient(to top, var(--hc-gold) 1px, transparent 1px) bottom left / 1px 14px no-repeat,
			linear-gradient(to left, var(--hc-gold) 1px, transparent 1px) bottom right / 14px 1px no-repeat,
			linear-gradient(to top, var(--hc-gold) 1px, transparent 1px) bottom right / 1px 14px no-repeat;
	}

	.hc-visual {
		display: block;
		width: 100%;
		height: auto;
	}

	.hc-plate {
		margin: 0.9rem 0 0;
		font-size: 0.7rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: color-mix(in srgb, var(--hc-gold) 75%, var(--hc-ivory) 25%);
		opacity: 0.75;
	}

	.hc-milestone--right .hc-plate {
		text-align: right;
	}

	/* Kawung motif (01) */
	.hc-v-ring { stroke: var(--hc-gold); stroke-width: 1; opacity: 0.4; }
	.hc-v-ring--dim { opacity: 0.22; }
	.hc-v-kawung { fill: none; stroke: var(--hc-gold); stroke-width: 1.3; opacity: 0.85; }
	.hc-v-dot { fill: var(--hc-gold); }

	/* Artisan hands (02) */
	.hc-v-wash { fill: color-mix(in srgb, var(--hc-gold) 10%, transparent); }
	.hc-v-cloth { stroke: var(--hc-gold); stroke-width: 1; opacity: 0.55; }
	.hc-v-cloth--dim { opacity: 0.3; }
	.hc-v-hand { fill: color-mix(in srgb, var(--hc-ivory) 88%, transparent); opacity: 0.92; }
	.hc-v-canting { stroke: var(--hc-bg); stroke-width: 1.4; stroke-linecap: round; }
	.hc-v-wax { stroke: var(--hc-gold); stroke-width: 1.2; stroke-linecap: round; opacity: 0.85; }

	/* Digital dissolve (03) */
	.hc-v-vine { stroke: var(--hc-gold); stroke-width: 1.4; opacity: 0.85; stroke-linecap: round; }
	.hc-v-vine--link { opacity: 0.5; stroke-dasharray: 2 3; }
	.hc-v-grid rect { fill: var(--hc-gold); }

	/* ------------------------------------ copy --------------------------------------- */

	.hc-copy {
		position: relative;
		padding-top: clamp(1.75rem, 3.5vw, 2.75rem);
	}

	.hc-num {
		position: absolute;
		top: -0.4rem;
		left: -0.5rem;
		font-family: var(--hc-heading-font);
		font-size: clamp(4rem, 3.4rem + 3vw, 7rem);
		line-height: 1;
		color: transparent;
		-webkit-text-stroke: 1px color-mix(in srgb, var(--hc-gold) 45%, transparent);
		opacity: 0.55;
		z-index: 0;
		pointer-events: none;
	}

	.hc-num-inline {
		display: inline-block;
		margin-right: 0.6em;
		font-family: var(--hc-body-font);
		font-size: 0.7rem;
		letter-spacing: 0.14em;
		vertical-align: middle;
		color: var(--hc-gold);
		padding-bottom: 0.35rem;
		border-bottom: 1px solid color-mix(in srgb, var(--hc-gold) 45%, transparent);
	}

	.hc-copy h3 {
		position: relative;
		z-index: 1;
		margin: 0;
		font-family: var(--hc-heading-font);
		font-weight: 500;
		font-size: clamp(1.5rem, 1.3rem + 1vw, 2.15rem);
		line-height: 1.18;
		color: var(--hc-ivory);
	}

	.hc-copy p {
		position: relative;
		z-index: 1;
		margin: 1rem 0 0;
		max-width: 38ch;
		font-size: clamp(0.95rem, 0.9rem + 0.2vw, 1.05rem);
		line-height: 1.75;
		color: color-mix(in srgb, var(--hc-ivory) 72%, transparent);
	}

	.hc-milestone--right .hc-copy p {
		margin-left: auto;
	}

	/* ------------------------------------ quote --------------------------------------- */

	.hc-quote {
		position: relative;
		z-index: 1;
		max-width: 980px;
		margin: 0 auto;
		padding-block: clamp(4rem, 12vh, 8rem) clamp(2.5rem, 6vh, 4rem);
		text-align: center;
	}

	.hc-quote blockquote {
		margin: 0;
	}

	.hc-quote-line {
		margin: 0;
	}

	.hc-quote .hc-line {
		font-family: var(--hc-heading-font);
		font-style: italic;
		font-weight: 400;
		font-size: clamp(1.5rem, 1.1rem + 2.4vw, 2.9rem);
		line-height: 1.4;
		color: var(--hc-ivory);
	}

	.hc-quote figcaption {
		margin-top: clamp(1.5rem, 3vh, 2rem);
		font-size: 0.75rem;
		letter-spacing: 0.24em;
		text-transform: uppercase;
		color: var(--hc-gold);
		opacity: 0.8;
	}

	.hc-thread-continue {
		position: relative;
		z-index: 1;
		height: clamp(6rem, 14vh, 10rem);
		margin-inline: auto;
		width: 1px;
		background: linear-gradient(to bottom, color-mix(in srgb, var(--hc-gold) 55%, transparent), transparent);
	}

	/* -------------------------------- responsive -------------------------------------- */

	@media (max-width: 820px) {
		.hc-milestone {
			grid-template-columns: 34px 1fr;
			column-gap: 1.25rem;
			padding-block: 3.5rem;
		}

		.hc-thread {
			left: 17px;
			width: 40px;
		}

		.hc-node {
			grid-column: 1;
		}

		.hc-milestone--left .hc-exhibit,
		.hc-milestone--left .hc-copy,
		.hc-milestone--right .hc-exhibit,
		.hc-milestone--right .hc-copy {
			grid-column: 2;
		}

		.hc-milestone--right {
			text-align: left;
		}

		.hc-milestone--right .hc-copy {
			align-items: flex-start;
		}

		.hc-milestone--right .hc-exhibit {
			margin-left: 0;
		}

		.hc-milestone--right .hc-plate {
			text-align: left;
		}

		.hc-milestone--right .hc-num {
			left: -0.5rem;
			right: auto;
		}

		.hc-milestone--right .hc-copy p {
			margin-left: 0;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.hc-mote,
		.hc-node::after {
			animation: none;
		}
	}

	/* If scripting is unavailable, never rely on JS to reveal content */
	@media (scripting: none) {
		.hc-line {
			transform: none;
		}
		.hc-paragraph,
		.hc-milestone {
			opacity: 1;
		}
	}
</style>

<script>
	import gsap from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	gsap.registerPlugin(ScrollTrigger);

	const root = document.querySelector<HTMLElement>(".hc");

	if (root) {
		const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

		// Optional: keep GSAP's ScrollTrigger in sync if Lenis smooth-scroll
		// is initialized elsewhere on the page (window.lenis).
		const lenis = (window as any).lenis;
		if (lenis) {
			lenis.on("scroll", ScrollTrigger.update);
			gsap.ticker.add((time: number) => lenis.raf(time * 1000));
			gsap.ticker.lagSmoothing(0);
		}

		/* ---------------------------- intro: eyebrow / heading / paragraph --------------------------- */

		const eyebrowRule = root.querySelector(".hc-eyebrow-rule");
		const headingLines = root.querySelectorAll(".hc-heading .hc-line");
		const paragraph = root.querySelector(".hc-paragraph");

		gsap.set(paragraph, { autoAlpha: 0, y: 18 });

		const introTl = gsap.timeline({
			scrollTrigger: {
				trigger: root.querySelector(".hc-intro"),
				start: "top 78%",
				once: true,
			},
			defaults: { ease: "power4.out" },
		});

		introTl
			.from(eyebrowRule, { scaleX: 0, transformOrigin: "left center", duration: 0.6, ease: "power3.out" })
			.to(headingLines, { y: "0%", duration: 1.05, stagger: 0.12 }, "-=0.25")
			.to(paragraph, { autoAlpha: 1, y: 0, duration: 0.9 }, "-=0.55");

		/* --------------------------------- thread: scroll-driven drawing ------------------------------ */

		const path = root.querySelector<SVGPathElement>(".hc-thread-draw");
		const maskRect = root.querySelector<SVGRectElement>(".hc-thread-mask-rect");
		const tipGlow = root.querySelector(".hc-tip-glow");
		const tipCore = root.querySelector(".hc-tip-core");
		const timelineEl = root.querySelector(".hc-timeline");

		if (path && timelineEl && maskRect) {
			const length = path.getTotalLength();

			const updateThread = (progress: number) => {
				const point = path.getPointAtLength(length * progress);
				gsap.set([tipGlow, tipCore], { attr: { cx: point.x, cy: point.y } });
				gsap.set(maskRect, { attr: { height: point.y } });
			};

			if (reduceMotion) {
				updateThread(1);
			} else {
				updateThread(0);
				gsap.to(maskRect, {
					// We use a dummy tween to attach the scroll trigger
					ease: "none",
					scrollTrigger: {
						trigger: timelineEl,
						start: "top 50%",
						end: "bottom 50%",
						scrub: true,
						onUpdate: (self) => updateThread(self.progress),
					},
				});
			}
		}

		/* ------------------------------------- milestones ------------------------------------------- */

		const milestones = root.querySelectorAll<HTMLElement>(".hc-milestone");
		milestones.forEach((el) => {
			const dir = el.classList.contains("hc-milestone--left") ? -1 : 1;

			gsap.fromTo(
				el,
				{ autoAlpha: 0, x: reduceMotion ? 0 : 36 * dir, y: 26 },
				{
					autoAlpha: 1,
					x: 0,
					y: 0,
					duration: 1,
					ease: "power3.out",
					scrollTrigger: {
						trigger: el,
						start: "top 82%",
						toggleActions: "play none none reverse",
					},
				},
			);

			const frame = el.querySelector(".hc-frame");
			const node = el.querySelector(".hc-node");

			if (node) {
				ScrollTrigger.create({
					trigger: node,
					start: "center 50%",
					onEnter: () => node.classList.add("is-active"),
					onLeaveBack: () => node.classList.remove("is-active"),
				});
			}

			if (frame && !reduceMotion) {
				gsap.to(frame, {
					yPercent: -6,
					ease: "none",
					scrollTrigger: {
						trigger: el,
						start: "top bottom",
						end: "bottom top",
						scrub: true,
					},
				});
			}
		});

		/* ---------------------------------------- quote ---------------------------------------------- */

		const quoteLines = root.querySelectorAll(".hc-quote .hc-line");
		const figcaption = root.querySelector(".hc-quote figcaption");
		gsap.set(figcaption, { autoAlpha: 0, y: 12 });

		gsap
			.timeline({
				scrollTrigger: {
					trigger: root.querySelector(".hc-quote"),
					start: "top 80%",
					once: true,
				},
				defaults: { ease: "power4.out" },
			})
			.to(quoteLines, { y: "0%", duration: 1.05, stagger: 0.14 })
			.to(figcaption, { autoAlpha: 1, y: 0, duration: 0.7 }, "-=0.4");
	}
</script>
