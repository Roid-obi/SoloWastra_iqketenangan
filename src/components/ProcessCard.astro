---
interface Props {
  image: string;
  title: string;
  description: string;
  index: number;
}

const { image, title, description, index } = Astro.props as Props;
---

<div class="mp-panel relative z-10 w-screen h-full shrink-0 flex flex-col lg:flex-row items-center justify-center gap-8 lg:gap-16 px-8 lg:px-24">
  <div class="w-full lg:w-1/2 aspect-4/3 lg:aspect-auto lg:h-[60vh] rounded-2xl overflow-hidden ring-1 ring-accent/10">
    <img src={image} alt={title} class="w-full h-full object-cover" />
  </div>
  <div class="w-full lg:w-1/2 max-w-lg">
    <p class="font-heading text-neutral-light sm:text-lg text-xs tracking-[0.25em] uppercase mb-2">
      {String(index + 1).padStart(2, "0")}
    </p>
    <h3 class="font-heading text-3xl sm:text-5xl lg:text-6xl text-neutral-light mt-2 leading-tight">
      {title}
    </h3>
    <p class="font-body text-base sm:text-lg text-neutral-light/50 mt-4 leading-relaxed max-w-[45ch]">
      {description}
    </p>
  </div>
</div>
