---
const navLinks = [
	{ href: "#hero", label: "Beranda" },
	{ href: "#story-wrapper", label: "Tentang" },
	{ href: "#gallery-section", label: "Koleksi" },
	{ href: "#mp-wrap", label: "Pembuatan" },
	{ href: "#timeline-container", label: "Sejarah" },
	{ href: "#modern-life-section", label: "Masa Kini" },
	{ href: "#preserving-heritage", label: "Dampak SDG 11" },
];
---

<!-- Hamburger Toggle Button -->
<div class="fixed top-6 right-6 z-[60]">
	<button
		id="menu-toggle"
		class="relative w-14 h-14 bg-[#eedfcc] text-[#603601] rounded-full flex items-center justify-center shadow-lg border-2 border-[#c8a97a] hover:bg-[#c8a97a] hover:text-[#fdfbf7] transition-colors duration-300 focus:outline-none focus:ring-4 focus:ring-[#cc9544]/50 group"
		aria-label="Toggle menu"
	>
		<!-- Icon Container for 3D flip rotation -->
		<div id="icon-wrapper" class="relative w-7 h-7 flex items-center justify-center transition-transform duration-700 group-hover:scale-110" style="transform-style: preserve-3d; transition-timing-function: cubic-bezier(0.68, -0.55, 0.265, 1.55);">
			<!-- Batik Themed Menu Icon (Front) -->
			<svg
				id="icon-batik"
				class="absolute inset-0 w-7 h-7 text-current"
				style="backface-visibility: hidden;"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				viewBox="0 0 24 24"
			>
				<path d="M3 7h18M8 12h8M3 17h18" />
				<circle cx="4" cy="12" r="1.5" fill="currentColor" stroke="none" />
				<circle cx="20" cy="12" r="1.5" fill="currentColor" stroke="none" />
			</svg>
			<!-- Batik Themed Close Icon (Back) -->
			<svg
				id="icon-close"
				class="absolute inset-0 w-7 h-7 text-current"
				style="backface-visibility: hidden; transform: rotateY(180deg);"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				viewBox="0 0 24 24"
			>
				<!-- X lines -->
				<path d="M6 6l12 12M6 18L18 6" />
				<!-- Kawung-style center & 4 directional dots -->
				<circle cx="12" cy="12" r="1.5" fill="currentColor" stroke="none" />
				<circle cx="12" cy="4" r="1" fill="currentColor" stroke="none" />
				<circle cx="12" cy="20" r="1" fill="currentColor" stroke="none" />
				<circle cx="4" cy="12" r="1" fill="currentColor" stroke="none" />
				<circle cx="20" cy="12" r="1" fill="currentColor" stroke="none" />
			</svg>
		</div>
	</button>
</div>

<!-- Fullscreen Menu Overlay -->
<div
	id="full-menu"
	class="fixed inset-0 z-50 bg-[#1c0a00]/95 backdrop-blur-xl flex items-center justify-center opacity-0 pointer-events-none transition-all duration-700 ease-in-out"
>
	<!-- Texture overlay for Batik feel -->
	<div
		class="absolute inset-0 opacity-20 pointer-events-none mix-blend-multiply"
		style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.8%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"
	>
	</div>

	<nav class="relative z-10 flex flex-col items-center gap-10">
		<div class="mb-4 text-center">
			<h2 class="font-heading text-2xl md:text-3xl font-bold text-[#cc9544] tracking-[0.3em] uppercase">
				SoloWastra
			</h2>
			<div class="w-16 h-px bg-[#cc9544]/50 mx-auto mt-4"></div>
		</div>

		<ul class="flex flex-col items-center gap-6 text-center w-full max-w-sm px-6">
			{
				navLinks.map((link) => (
					<li class="w-full overflow-hidden">
						<a
							href={link.href}
							class="nav-link block font-heading text-4xl md:text-5xl text-[#fdfbf7] hover:text-[#cc9544] transition-all duration-300 transform hover:scale-110 hover:-translate-y-1 py-2"
						>
							{link.label}
						</a>
					</li>
				))
			}
		</ul>
	</nav>
</div>

<style>
	.nav-link.active {
		color: #cc9544 !important;
		font-style: italic;
		transform: scale(1.1);
	}
</style>

<script>
	import { getLenis } from "../lib/smooth-scroll";

	document.addEventListener("DOMContentLoaded", () => {
		const menuToggle = document.getElementById("menu-toggle");
		const fullMenu = document.getElementById("full-menu");
		const iconWrapper = document.getElementById("icon-wrapper");
		const navLinks = document.querySelectorAll(".nav-link");

		let isMenuOpen = false;

		function toggleMenu() {
			isMenuOpen = !isMenuOpen;

			if (isMenuOpen) {
				// Open menu
				fullMenu?.classList.remove("opacity-0", "pointer-events-none");
				fullMenu?.classList.add("opacity-100", "pointer-events-auto");

				// 3D Flip to Close Icon
				if (iconWrapper) {
					iconWrapper.style.transform = "rotateY(180deg) rotateZ(90deg)";
				}
			} else {
				// Close menu
				fullMenu?.classList.remove("opacity-100", "pointer-events-auto");
				fullMenu?.classList.add("opacity-0", "pointer-events-none");

				// 3D Flip back to Hamburger Icon
				if (iconWrapper) {
					iconWrapper.style.transform = "rotateY(0deg) rotateZ(0deg)";
				}
			}
		}

		menuToggle?.addEventListener("click", toggleMenu);

		navLinks.forEach((link) => {
			link.addEventListener("click", (e) => {
				const targetHref = link.getAttribute("href");
				if (targetHref && targetHref.startsWith("#")) {
					e.preventDefault();
					toggleMenu();
					
					const targetElement = document.querySelector(targetHref);
					const lenis = getLenis();
					
					// Slight delay to allow menu closing animation to start
					setTimeout(() => {
						if (lenis && targetElement) {
							lenis.scrollTo(targetElement, { duration: 1.5, easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)) });
						} else if (targetElement) {
							targetElement.scrollIntoView({ behavior: "smooth" });
						}
					}, 200);
				}
			});
		});

		// Intersection Observer for Active State
		const observerOptions = {
			root: null,
			rootMargin: "-20% 0px -60% 0px", // Trigger when section is in the middle of viewport
			threshold: 0,
		};

		const observer = new IntersectionObserver((entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					const id = entry.target.id;
					navLinks.forEach((link) => {
						if (link.getAttribute("href") === `#${id}`) {
							link.classList.add("active");
						} else {
							link.classList.remove("active");
						}
					});
				}
			});
		}, observerOptions);

		// Observe relevant sections
		navLinks.forEach(link => {
			const targetHref = link.getAttribute("href");
			if (targetHref && targetHref.startsWith("#")) {
				const section = document.querySelector(targetHref);
				if (section) observer.observe(section);
			}
		});
	});
</script>
