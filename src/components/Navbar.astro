---
const navLinks = [
	{ href: "#about", label: "Tentang" },
	{ href: "#explore-motifs", label: "Motif" },
	{ href: "#crafting-process", label: "Proses" },
	{ href: "#historical-timeline", label: "Sejarah" },
	{ href: "#preserving-heritage", label: "SDG 11" },
];
---

<header
	id="site-navbar"
	class="fixed inset-x-0 top-0 z-50 transition-colors duration-500"
	data-state="top"
>
	<nav class="section-container flex items-center justify-between py-4 md:py-5">
		<a
			href="#hero"
			class="font-heading text-lg tracking-wide text-neutral-light md:text-xl"
			data-nav-logo
		>
			SoloWastra
		</a>

		<ul class="hidden items-center gap-8 md:flex">
			{
				navLinks.map((link) => (
					<li>
						<a
							href={link.href}
							class="text-sm font-medium text-neutral-light/85 transition-colors duration-300 hover:text-accent"
							data-nav-link
						>
							{link.label}
						</a>
					</li>
				))
			}
		</ul>

		<button
			type="button"
			id="nav-toggle"
			class="flex h-10 w-10 items-center justify-center rounded-full border border-neutral-light/30 text-neutral-light md:hidden"
			aria-label="Buka menu navigasi"
			aria-expanded="false"
		>
			<svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
				<path d="M1 4h16M1 9h16M1 14h16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
			</svg>
		</button>
	</nav>

	<div
		id="nav-mobile-menu"
		class="pointer-events-none absolute inset-x-0 top-full origin-top scale-y-95 bg-neutral-dark/98 opacity-0 backdrop-blur transition-all duration-300 md:hidden"
	>
		<ul class="section-container flex flex-col gap-1 py-4">
			{
				navLinks.map((link) => (
					<li>
						<a
							href={link.href}
							class="block rounded-lg px-2 py-3 text-base text-neutral-light/90 transition-colors hover:bg-neutral-light/5 hover:text-accent"
							data-nav-link
						>
							{link.label}
						</a>
					</li>
				))
			}
		</ul>
	</div>
</header>

<style>
	#site-navbar[data-state="scrolled"] {
		background-color: color-mix(in srgb, var(--color-neutral-dark) 88%, transparent);
		backdrop-filter: blur(10px);
		box-shadow: 0 1px 0 0 rgba(253, 251, 247, 0.06);
	}

	#nav-mobile-menu[data-open="true"] {
		pointer-events: auto;
		opacity: 1;
		transform: scaleY(1);
	}
</style>

<script>
	const navbar = document.getElementById("site-navbar");
	const toggle = document.getElementById("nav-toggle");
	const mobileMenu = document.getElementById("nav-mobile-menu");

	const onScroll = () => {
		if (!navbar) return;
		navbar.dataset.state = window.scrollY > 40 ? "scrolled" : "top";
	};
	onScroll();
	window.addEventListener("scroll", onScroll, { passive: true });

	let open = false;
	const setOpen = (value: boolean) => {
		open = value;
		mobileMenu?.setAttribute("data-open", String(value));
		toggle?.setAttribute("aria-expanded", String(value));
	};

	toggle?.addEventListener("click", () => setOpen(!open));
	mobileMenu?.querySelectorAll("a").forEach((a) => {
		a.addEventListener("click", () => setOpen(false));
	});
</script>
