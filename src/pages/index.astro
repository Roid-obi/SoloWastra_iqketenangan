---
import ClosingCta from "../components/ClosingCta.astro";
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";
import PreservingHeritage from "../components/PreservingHeritage.astro";
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Introduction from "../components/Introduction.astro";
import WhySolo from "../components/WhySolo.astro";
import Gallery from "../components/Gallery.astro";
import BatikModal from "../components/BatikModal.astro";
---

<Layout>
	<Navbar />
	<main class="relative w-full">
		<Hero />

		<!-- Scrollytelling Stacking Section -->
		<div id="story-wrapper" class="relative w-full">
			
			<!-- Sticky Container for Introduction -->
			<div class="sticky top-0 w-full h-screen flex flex-col justify-center overflow-hidden z-10" id="intro-container">
				<Introduction />
			</div>

			<!-- Spacer to create scroll distance for pinning effect -->
			<div class="h-screen w-full"></div>

			<!-- Sticky Container for WhySolo -->
			<div class="sticky top-0 w-full h-screen flex flex-col justify-center overflow-hidden z-20 pointer-events-none" id="why-container">
				<div class="pointer-events-auto w-full h-full">
					<WhySolo />
				</div>
			</div>
			
			<!-- Final Spacer -->
			<div class="h-screen w-full"></div>

		</div>

		<!-- Gallery Section -->
		<Gallery />

	</main>
	
	<!-- Modals -->
	<BatikModal />
</Layout>

<script>
	import { initSmoothScroll } from "../lib/smooth-scroll";
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	initSmoothScroll();
	
	// Register ScrollTrigger
	gsap.registerPlugin(ScrollTrigger);

	// Animate Introduction Text
	gsap.to(".blur-text", {
		filter: "blur(0px)",
		opacity: 1,
		y: 0,
		stagger: 0.3,
		duration: 1.2,
		ease: "power2.out",
		scrollTrigger: {
			trigger: "#intro-container",
			start: "top center",
		}
	});

	// Animate Introduction Card (Shrink and rotate left)
	gsap.to(".intro-card", {
		scrollTrigger: {
			trigger: "#intro-container",
			start: "top top",
			end: "bottom top",
			scrub: true,
		},
		scale: 0.9,
		rotation: -3,
		opacity: 0.8,
		ease: "none",
	});

	// Animate WhySolo Card (Shrink and rotate right)
	gsap.to(".why-card", {
		scrollTrigger: {
			trigger: "#why-container",
			start: "top top",
			end: "bottom top",
			scrub: true,
		},
		scale: 0.9,
		rotation: 3,
		ease: "none",
	});
</script>
